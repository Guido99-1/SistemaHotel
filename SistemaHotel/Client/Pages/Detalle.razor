    // {
    //     if (_clienteDTO == null || string.IsNullOrWhiteSpace(_clienteDTO.NombreCompleto))
    //     {
    //         await Swal.FireAsync("Falta cliente", "Debe seleccionar o crear un cliente.", "warning");
    //         return;
    //     }

    //     if (fechaSalida < fechaEntrada)
    //     {
    //         await Swal.FireAsync("Fechas inválidas", "La fecha de salida no puede ser menor a la fecha de entrada.", "warning");
    //         return;
    //     }

    //     RecalcularPrecio();

    //     var total = precioFinal ?? 0m;
    //     var adelanto = _recepcionDTO.Adelanto ?? 0m;

    //     if (adelanto < 0m) adelanto = 0m;

    //     // ✅ Validación clave: adelanto no puede ser mayor al total
    //     if (adelanto > total)
    //     {
    //         await Swal.FireAsync("Error", "El adelanto no puede ser mayor al total.", "warning");
    //         return;
    //     }

    //     // ✅ Recomendado: obligar elegir método de pago antes de registrar
    //     if (string.IsNullOrWhiteSpace(_recepcionDTO.MetodoPago))
    //     {
    //         await Swal.FireAsync("Falta método de pago", "Selecciona el método de pago antes de registrar.", "warning");
    //         return;
    //     }

    //     _recepcionDTO.IdClienteNavigation = _clienteDTO;
    //     _recepcionDTO.IdHabitacion = _habitacionDTO.IdHabitacion;

    //     _recepcionDTO.FechaEntrada = fechaEntrada;
    //     _recepcionDTO.FechaSalida = fechaSalida;

    //     _recepcionDTO.PrecioInicial = total;
    //     _recepcionDTO.PrecioRestante = total - adelanto;

    //     var response = await _recepcionServicio.Crear(_recepcionDTO);

    //     if (response.status)
    //     {
    //         await Swal.FireAsync("Éxito", "La recepción fue registrada correctamente.", "success");
    //         navManager.NavigateTo("/page/recepcion");
    //     }
    //     else
    //     {
    //         await Swal.FireAsync("No se pudo registrar", response.msg, "error");
    //     }
    // }
    private async Task Registrar()
    {
        // 1) Cliente
        if (_clienteDTO == null || string.IsNullOrWhiteSpace(_clienteDTO.NombreCompleto))
        {
            await Swal.FireAsync("Falta cliente", "Debe seleccionar o crear un cliente.", "warning");
            return;
        }

        // 2) Fechas
        if (fechaSalida < fechaEntrada)
        {
            await Swal.FireAsync("Fechas inválidas", "La fecha de salida no puede ser menor a la fecha de entrada.", "warning");
            return;
        }

        // 3) Precio
        RecalcularPrecio();
        decimal precioInicial = precioFinal ?? 0m;

        if (precioInicial <= 0m)
        {
            await Swal.FireAsync("Error", "El precio inicial no puede ser 0.", "warning");
            return;
        }

        // 4) Adelanto (puede ser 0)
        decimal adelanto = _recepcionDTO.Adelanto ?? 0m;
        if (adelanto < 0m) adelanto = 0m;

        // ✅ Validación clave: adelanto no puede superar el precio inicial
        if (adelanto > precioInicial)
        {
            await Swal.FireAsync("Error", "El adelanto no puede ser mayor al precio inicial.", "warning");
            return;
        }

        // ✅ Método de pago obligatorio (ya que cobrarás en check-in)
        if (string.IsNullOrWhiteSpace(_recepcionDTO.MetodoPago))
        {
            await Swal.FireAsync("Falta método de pago", "Selecciona el método de pago.", "warning");
            return;
        }

        // 5) Asignar relaciones
        _recepcionDTO.IdCliente = _clienteDTO.IdCliente;
        _recepcionDTO.IdHabitacion = _habitacionDTO.IdHabitacion;

        _recepcionDTO.FechaEntrada = fechaEntrada;
        _recepcionDTO.FechaSalida = fechaSalida;

        // 6) Guardar reglas de negocio
        _recepcionDTO.PrecioInicial = precioInicial;
        _recepcionDTO.Adelanto = adelanto;

        // ✅ PENDIENTE A COBRAR EN CHECK-IN
        _recepcionDTO.PrecioRestante = precioInicial - adelanto; // caso 1/2/3 sale perfecto

        // ✅ Penalidad empieza en 0
        _recepcionDTO.CostoPenalidad = _recepcionDTO.CostoPenalidad ?? 0m;
        if (_recepcionDTO.CostoPenalidad < 0m) _recepcionDTO.CostoPenalidad = 0m;

        // ✅ TotalPagado (sin penalidad aún)
        _recepcionDTO.TotalPagado = precioInicial;

        // 7) Guardar
        var response = await _recepcionServicio.Crear(_recepcionDTO);

        if (response.status)
        {
            await Swal.FireAsync("Éxito", "La recepción fue registrada correctamente.", "success");
            navManager.NavigateTo("/page/recepcion");
        }
        else
        {
            await Swal.FireAsync("No se pudo registrar", response.msg, "error");
        }
    }
}