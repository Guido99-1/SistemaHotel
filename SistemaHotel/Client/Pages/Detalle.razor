@page "/page/detalle/{idHabitacion:int}"

@inject IHabitacionServicio _habitacionServicio
@inject IRecepcionServicio _recepcionServicio
@inject IDialogService DialogService
@inject SweetAlertService Swal
@inject NavigationManager navManager

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-5">

    <MudText Typo="Typo.h5" GutterBottom="true">Detalle</MudText>

    <MudPaper Elevation="3" Class="pa-4" Width="100%">

        <!-- HABITACION -->
        <MudGrid>
            <MudItem xs="12">
                <MudCard>
                    <MudCardHeader Class="pb-0">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Habitación</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>

                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" lg="6" md="6" sm="6">
                                <MudTextField Value="_habitacionDTO.Numero"
                                              Label="Numero"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" lg="6" md="6" sm="6">
                                <MudTextField Value="_habitacionDTO.IdCategoriaNavigation?.Descripcion"
                                              Label="Categoria"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" lg="6" md="6" sm="6">
                                <MudTextField Value="_habitacionDTO.Detalle"
                                              Label="Detalle"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" lg="6" md="6" sm="6">
                                <MudTextField Value="_habitacionDTO.IdPisoNavigation?.Descripcion"
                                              Label="Piso"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <MudGrid>

            <!-- CLIENTE -->
            <MudItem xs="12" lg="6" md="6" sm="6">
                <MudCard>
                    <MudCardHeader Class="pb-0">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Cliente</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>

                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudGrid>
                                    <MudItem xs="6">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Info"
                                                   FullWidth="true"
                                                   Size="Size.Small"
                                                   OnClick="Buscar">
                                            Buscar
                                        </MudButton>
                                    </MudItem>

                                    <MudItem xs="6">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   FullWidth="true"
                                                   Size="Size.Small"
                                                   OnClick="CrearCliente">
                                            Crear
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.TipoDocumento"
                                              Label="Tipo Documento"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.Documento"
                                              Label="Documento"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.NombreCompleto"
                                              Label="Nombre Completo"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.Correo"
                                              Label="Correo"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.Telefono"
                                              Label="telefono"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_clienteDTO.Direccion"
                                              Label="Direccion"
                                              Disabled="@(!_crearCliente)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- RECEPCION -->
            <MudItem xs="12" lg="6" md="6" sm="6">
                <MudCard>
                    <MudCardHeader Class="pb-0">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Recepción</MudText>
                        </CardHeaderContent>

                        <CardHeaderActions>
                            <MudButton Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="Registrar"
                                       Color="Color.Primary"
                                       Size="Size.Small">
                                Registrar
                            </MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>

                    <MudCardContent>
                        <MudGrid>

                            <MudItem xs="12">
                                <MudDatePicker Label="Fecha Entrada"
                                               PickerVariant="PickerVariant.Dialog"
                                               Margin="Margin.Dense"
                                               DisableToolbar="true"
                                               Variant="Variant.Outlined"
                                               DateFormat="dd/MM/yyyy"
                                               Date="fechaEntrada"
                                               ReadOnly="true"
                                               Disabled="true" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudDatePicker Label="Fecha Salida"
                                               PickerVariant="PickerVariant.Dialog"
                                               Margin="Margin.Dense"
                                               DisableToolbar="true"
                                               Variant="Variant.Outlined"
                                               DateFormat="dd/MM/yyyy"
                                               Date="fechaSalida"
                                               DateChanged="OnFechaSalidaChanged"
                                               MinDate="@fechaEntrada" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudNumericField T="decimal?"
                                                 Value="precioFinal"
                                                 ValueChanged="(v)=>precioFinal=v"
                                                 Label="Precio (por noches)"
                                                 Variant="Variant.Outlined"
                                                 ReadOnly="true"
                                                 Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudNumericField T="decimal?"
                                                 @bind-Value="_recepcionDTO.Adelanto"
                                                 Label="Adelanto"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Min="0" />
                            </MudItem>

                            <!-- ✅ Botón Cobrar dentro de MudItem -->
                            <MudItem xs="12">
                                <MudButton Color="Color.Success"
                                           Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Payments"
                                           FullWidth="true"
                                           OnClick="CobrarConMetodo">
                                    Seleccionar método de pago
                                </MudButton>
                            </MudItem>

                            <!-- ✅ Mostrar elegido -->
                            <MudItem xs="12">
                                <MudText Typo="Typo.body2">
                                    <b>Método:</b> @_recepcionDTO.MetodoPago
                                    @if (!string.IsNullOrWhiteSpace(_recepcionDTO.NotaMetodoPago))
                                    {
                                        <span> | <b>Nota:</b> @_recepcionDTO.NotaMetodoPago</span>
                                    }
                                </MudText>
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_recepcionDTO.Observacion"
                                              Label="Observación"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                    Se cobra por <b>noche</b>. Ejemplo: entrada 19 y salida 20 = <b>1 noche</b>.
                                    <br />
                                    Si eliges salida hoy, se cobra como <b>1 noche</b> (day use).
                                </MudAlert>
                            </MudItem>

                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>

    </MudPaper>
</MudContainer>

@code {

    [Parameter] public int idHabitacion { get; set; }

    private ClienteDTO _clienteDTO = new();
    private RecepcionDTO _recepcionDTO = new();

    private bool _crearCliente = false;

    private decimal? precioFinal = 0;

    private DateTime fechaEntrada = DateTime.Today;
    private DateTime fechaSalida = DateTime.Today.AddDays(1);

    private HabitacionDTO _habitacionDTO = new()
    {
        IdEstadoHabitacionNavigation = new EstadoHabitacionDTO(),
        IdCategoriaNavigation = new CategoriaDTO(),
        IdPisoNavigation = new PisoDTO()
    };

    protected override async Task OnParametersSetAsync()
    {
        var response = await _habitacionServicio.Obtener(idHabitacion);

        if (response.status && response.value != null)
        {
            _habitacionDTO = response.value;

            fechaEntrada = DateTime.Today;
            fechaSalida = DateTime.Today.AddDays(1);

            RecalcularPrecio();
        }
        else
        {
            await Swal.FireAsync("Error", "No se pudo cargar la habitación.", "error");
        }
    }

    private Task CrearCliente()
    {
        _crearCliente = true;
        _clienteDTO = new ClienteDTO();
        return Task.CompletedTask;
    }

    private async Task Buscar()
    {
        DialogOptions options = new() { Position = DialogPosition.TopCenter, NoHeader = true };
        var dialogo = DialogService.Show<MdClientes>("", options);
        var resultado = await dialogo.Result;

        if (!resultado.Canceled && resultado.Data is ClienteDTO cliente)
        {
            _crearCliente = false;
            _clienteDTO = cliente;
        }
    }

    private void OnFechaSalidaChanged(DateTime? nuevaSalida)
    {
        if (nuevaSalida == null) return;

        fechaSalida = nuevaSalida.Value.Date;

        if (fechaSalida < fechaEntrada)
            fechaSalida = fechaEntrada;

        RecalcularPrecio();
    }

    // private void RecalcularPrecio()
    // {
    //     if (_habitacionDTO.Precio == null)
    //     {
    //         precioFinal = 0;
    //         return;
    //     }

    //     var noches = (fechaSalida.Date - fechaEntrada.Date).Days;
    //     if (noches <= 0) noches = 1;

    //     precioFinal = _habitacionDTO.Precio.Value * noches;
    // }
    private void RecalcularPrecio()
    {
        if (_habitacionDTO.Precio == null)
        {
            precioFinal = 0m;
            return;
        }

        var entrada = fechaEntrada.Date;
        var salida = fechaSalida.Date;

        var noches = (salida - entrada).Days;

        // day-use o mismo día => 1 noche
        if (noches <= 0) noches = 1;

        precioFinal = _habitacionDTO.Precio.Value * noches;
    }

    // ✅ Usa el MISMO modal que en Registrar (MdMetodoPago)
    private async Task CobrarConMetodo()
    {
        var dialog = DialogService.Show<MdMetodoPago>("Método de pago");
        var result = await dialog.Result;

        if (result.Canceled)
            return;

        if (result.Data is not MdMetodoPago.MetodoPagoResult data)
        {
            await Swal.FireAsync("Error", "No se pudo leer el método de pago.", "error");
            return;
        }

        _recepcionDTO.MetodoPago = data.MetodoPago;
        _recepcionDTO.NotaMetodoPago = data.NotaMetodoPago;
    }

