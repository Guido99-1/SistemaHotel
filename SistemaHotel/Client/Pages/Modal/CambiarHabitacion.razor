@using MudBlazor
@using SistemaHotel.Shared
@inject IHabitacionServicio _habitacionServicio
@inject IRecepcionServicio _recepcionServicio
@inject SweetAlertService Swal

<MudDialog>
    <DialogContent>

        @if (cargando)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else
        {
            <MudStack Spacing="2">

                <MudPaper Elevation="0" Class="pa-3 mud-border-radius-8" Style="border:1px solid rgba(0,0,0,.08);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">Cambio de habitación</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Recepción ID: @IdRecepcion
                        </MudText>
                    </MudStack>
                </MudPaper>

                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Habitación actual</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@NumeroHabitacionActual"
                                              Label="Número"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@DetalleHabitacionActual"
                                              Label="Detalle"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@CategoriaActual"
                                              Label="Categoría"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@PisoActual"
                                              Label="Piso"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>

                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Nueva habitación</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudSelect T="int?"
                                           Label="Selecciona una habitación disponible"
                                           @bind-Value="idNuevaHabitacion"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense">
                                    @foreach (var h in habitacionesDisponibles)
                                    {
                                        <MudSelectItem Value="@((int?)h.IdHabitacion)">
                                            @($"{h.Numero} - {h.Detalle} - {h.IdCategoriaNavigation?.Descripcion}")
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                    La habitación actual pasará a <b>Limpieza</b> y la nueva habitación pasará a <b>Ocupada</b>.
                                </MudAlert>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        }

    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar">
            Cancelar
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(cargando || guardando || !idNuevaHabitacion.HasValue)"
                   OnClick="Guardar">
            @if (guardando)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            }
            Confirmar cambio
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int IdRecepcion { get; set; }
    [Parameter] public int IdHabitacionActual { get; set; }
    [Parameter] public string NumeroHabitacionActual { get; set; } = "";
    [Parameter] public string DetalleHabitacionActual { get; set; } = "";
    [Parameter] public string CategoriaActual { get; set; } = "";
    [Parameter] public string PisoActual { get; set; } = "";

    private bool cargando = true;
    private bool guardando = false;
    private int? idNuevaHabitacion;
    private List<HabitacionDTO> habitacionesDisponibles = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargando = true;

            var resp = await _habitacionServicio.ListaDisponibles();

            if (!resp.status || resp.value == null)
            {
                await Swal.FireAsync("Error", resp.msg ?? "No se pudo cargar las habitaciones disponibles.", "error");
                MudDialog.Cancel();
                return;
            }

            habitacionesDisponibles = resp.value
                .Where(h => h.IdHabitacion != IdHabitacionActual)
                .ToList();

            if (habitacionesDisponibles.Count == 0)
            {
                await Swal.FireAsync("Sin disponibilidad", "No hay habitaciones disponibles para realizar el cambio.", "info");
                MudDialog.Cancel();
                return;
            }
        }
        finally
        {
            cargando = false;
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Guardar()
    {
        if (!idNuevaHabitacion.HasValue || idNuevaHabitacion <= 0)
        {
            await Swal.FireAsync("Falta selección", "Debes seleccionar una nueva habitación.", "warning");
            return;
        }

        if (idNuevaHabitacion.Value == IdHabitacionActual)
        {
            await Swal.FireAsync("Habitación inválida", "Debes seleccionar una habitación diferente a la actual.", "warning");
            return;
        }

        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Confirmar cambio?",
            Text = "La habitación actual pasará a limpieza y la nueva habitación pasará a ocupada.",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, cambiar",
            CancelButtonText = "Cancelar"
        });

        if (!confirm.IsConfirmed)
            return;

        try
        {
            guardando = true;

            var resp = await _recepcionServicio.CambiarHabitacion(new CambiarHabitacionDTO
            {
                IdRecepcion = IdRecepcion,
                IdNuevaHabitacion = idNuevaHabitacion.Value
            });

            if (resp.status)
            {
                MudDialog.Close(DialogResult.Ok(idNuevaHabitacion.Value));
            }
            else
            {
                await Swal.FireAsync("Error", resp.msg ?? "No se pudo cambiar la habitación.", "error");
            }
        }
        finally
        {
            guardando = false;
        }
    }
}