@page "/page/dashboard"

@inject IDashBoardServicio _dashboardServicio;
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-5">

    <MudPaper Elevation="3" Class="pa-4" Width="100%">

        <MudGrid>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Class="mx-4" Style="width:54px; height:54px;"></MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">Total Habitaciones</MudText>
                        <MudText Typo="Typo.h5">@dashboardDTO.TotalHabitaciones</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Secondary" Class="mx-4" Style="width:54px; height:54px;"></MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">Habitaciones Disponibles</MudText>
                        <MudText Typo="Typo.h5">@dashboardDTO.TotalHabitacionesDisponibles</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Success" Class="mx-4" Style="width:54px; height:54px;"></MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">Habitaciones Ocupadas</MudText>
                        <MudText Typo="Typo.h5">@dashboardDTO.TotalHabitacionesOcupadas</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Error" Class="mx-4" Style="width:54px; height:54px;"></MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">Habitaciones Limpieza</MudText>
                        <MudText Typo="Typo.h5">@dashboardDTO.TotalHabitacionesEnLimpieza</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.EventAvailable"
                             Color="Color.Success"
                             Class="mx-4"
                             Style="width:54px; height:54px;">
                    </MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">
                            Reservas de hoy
                        </MudText>
                        <MudText Typo="Typo.h5">
                            @dashboardDTO.TotalReservasHoy
                        </MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem sm="12" md="6" xs="12">
                <MudPaper Elevation="25" Class="d-flex flex-row pt-6 pb-4" Style="height:100px;">
                    <MudIcon Icon="@Icons.Material.Filled.DateRange"
                             Color="Color.Info"
                             Class="mx-4"
                             Style="width:54px; height:54px;">
                    </MudIcon>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-n1">
                            Reservas del mes
                        </MudText>
                        <MudText Typo="Typo.h5">
                            @dashboardDTO.TotalReservasMes
                        </MudText>
                    </div>
                </MudPaper>
            </MudItem>



        </MudGrid>

    </MudPaper>

</MudContainer>
@code {
    DashBoardDTO dashboardDTO = new DashBoardDTO();

    int totalReservasHoy;
    int totalReservasMes;

    protected override async Task OnInitializedAsync()
    {
        dashboardDTO.TotalHabitaciones =
        await _dashboardServicio.TotalHabitaciones();

        dashboardDTO.TotalHabitacionesDisponibles =
    await _dashboardServicio.TotalHabitacionesDisponibles();

        dashboardDTO.TotalHabitacionesOcupadas =
            await _dashboardServicio.TotalHabitacionesOcupadas();

        dashboardDTO.TotalHabitacionesEnLimpieza =
            await _dashboardServicio.TotalHabitacionesEnLimpieza();


        dashboardDTO.TotalReservasHoy =
            await _dashboardServicio.TotalReservasHoy();

        dashboardDTO.TotalReservasMes =
            await _dashboardServicio.TotalReservasMes();
    }
}
