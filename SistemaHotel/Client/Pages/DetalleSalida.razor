    //         Icon = SweetAlertIcon.Warning,
    //         ShowCancelButton = true,
    //         ConfirmButtonText = "Sí, finalizar",
    //         CancelButtonText = "Cancelar"
    //     });

    //     if (!confirm.IsConfirmed)
    //         return;

    //     // Validación: que haya recepción cargada
    //     if (_recepcionDTO == null || _recepcionDTO.IdRecepcion <= 0)
    //     {
    //         await Swal.FireAsync("Error", "No se encontró una recepción activa para finalizar.", "error");
    //         return;
    //     }
    //     //✅ Normalizar penalidad
    //         var penalidad = _recepcionDTO.CostoPenalidad ?? 0m;
    //         if (penalidad < 0m) penalidad = 0m;

    //         _recepcionDTO.CostoPenalidad = penalidad;
    //     // ✅ Total final: precio base + penalidad
    //         var baseHospedaje = _recepcionDTO.PrecioInicial ?? 0m;
    //         _recepcionDTO.TotalPagado = baseHospedaje + penalidad;

    //     var resp = await _recepcionServicio.Finalizar(_recepcionDTO.IdRecepcion);

    //     if (resp.status)
    //     {
    //         await Swal.FireAsync("Éxito", resp.msg, "success");
    //         navManager.NavigateTo("/page/salida");
    //     }
    //     else
    //     {
    //         await Swal.FireAsync("No se pudo finalizar", resp.msg, "error");
    //     }
    // }
    private async Task Finalizar()
    {
        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Finalizar recepción?",
            Text = "Se realizará el check-out y se liberará la habitación.",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, finalizar",
            CancelButtonText = "Cancelar"
        });

        if (!confirm.IsConfirmed)
            return;

        if (_recepcionDTO == null || _recepcionDTO.IdRecepcion <= 0)
        {
            await Swal.FireAsync("Error", "No se encontró la recepción.", "error");
            return;
        }

        decimal penalidad = _recepcionDTO.CostoPenalidad ?? 0m;

        // ✅ AQUÍ ESTÁ LA CORRECCIÓN
        var ok = await _recepcionServicio.Finalizar(
            _recepcionDTO.IdRecepcion,
            DateTime.Now,
            penalidad
        );

        if (ok)
        {
            await Swal.FireAsync("Check-out realizado", "Habitación liberada correctamente.", "success");

            navManager.NavigateTo("/page/recepcion", true);
        }
        else
        {
            await Swal.FireAsync("Error", "No se pudo finalizar.", "error");
        }
    }
   


}
